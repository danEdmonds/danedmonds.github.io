---
layout: base
---

<header role="banner">
    <div class="container">
        {% include nav.html %}
    </div>

    <div class="hero animate">
        <!-- <svg viewBox="0 0 128 99.63" class="logo" aria-hidden="true">
            <path d="M34.43 11.38C45.45.36 63.31.36 74.32 11.38l17.73 17.73a3.138 3.138 0 0 0 4.43 0l8.87-8.87a3.138 3.138 0 0 1 4.43 0l13.3 13.3a3.138 3.138 0 0 1 0 4.43L80.97 80.08a6.27 6.27 0 0 1-8.87 0L47.72 55.7a3.138 3.138 0 0 1 0-4.43l4.43-4.43a3.138 3.138 0 0 1 4.43 0l8.87 8.87a3.138 3.138 0 0 0 4.43 0l2.22-2.22a6.27 6.27 0 0 0 0-8.87l-13.3-13.3a6.27 6.27 0 0 0-8.87 0L32.21 49.05a6.27 6.27 0 0 0 0 8.87l19.95 19.95a3.138 3.138 0 0 1 0 4.43l-13.3 13.3a3.138 3.138 0 0 1-4.43 0L12.26 73.43c-11.02-11.02-11.02-28.88 0-39.89l22.17-22.16z" />
        </svg> -->

        <div class="container">
            {%- if page.title -%}
                <h1 class="page-heading" data-title="{{ page.title }}">{{ page.title }}</h1>
            {%- endif -%}

            {{ content }}
        </div>
    </div>
</header>

<main>
    {% assign projects = site.projects | sort: 'order' | reverse %}
    {%- if projects.size > 0 -%}
        <div class="container">
            <h2 id="my-work">My work.</h2>

            {%- for post in projects -%}
                {% assign class_list = "project" %}

                {% if post.publish != false %}
                    {% if post.slug %}
                        {% assign class_list = class_list | append: " project--" | append: post.slug %}
                    {% endif %}
                  
                    <div class="{{ class_list }}">
                        <div class="project__details">
                            <h3 class="project__name"><a href="{{ post.url | relative_url }}">{{ post.title | escape }}</a></h3>

                            {% if post.summary %}
                                <p class="project__summary">{{ post.summary }}</p>
                            {% endif %}
                        </div>
                        
                        <a href="{{ post.url | relative_url }}" class="project__image" aria-label="View the {{ post.title | escape }} project.">
                            <img src="{{ site.baseurl }}/assets/images/{{ post.url }}/{{ post.thumbnail }}" alt="" width="480" height="360">
                        </a>
                    </div>
                {% endif %}
            {%- endfor -%}
        </div>
    {%- endif -%}

    <canvas id="canvas" width="500" height="500" style="position: fixed; bottom: 20px; left: 20px; display: block;"></canvas>
</main>

<script src="https://unpkg.com/@rive-app/canvas"></script>

<script>
    let boundInstance;
let lastScrollY = window.scrollY;
let lastScrollTime = performance.now();
let pedalSpeed = 0;

const MAX_SCROLL_SPEED = 8.0;  // raw scroll speed cap
const MAX_PEDAL_SPEED = 3;     // pedal speed cap for animation

let scrollTimeout = null;

const r = new rive.Rive({
  src: "/assets/images/pedaltest.riv",
  canvas: document.getElementById("canvas"),
  autoplay: true,
  autoBind: true,
  artboard: "Artboard",
  stateMachines: "State Machine 1",
  onLoad: () => {
    boundInstance = r.viewModelInstance;
  },
});

// Update both PedalSpeed and PedalState
function updatePedalSpeed(newSpeed) {
  pedalSpeed = newSpeed;
  let pedalState = "Idle";

  if (boundInstance) {
    boundInstance.number("PedalSpeed").value = pedalSpeed.toFixed(1);

    if (pedalSpeed === 0) {
      pedalState = "Idle";
    } else if (pedalSpeed <= 1) {
      pedalState = "Slow";
    } else if (pedalSpeed <= 2) {
      pedalState = "Moderate";
    } else {
      pedalState = "Fast";
    }

    boundInstance.string("PedalState").value = pedalState;
  }

  console.log("Pedal Speed:", pedalSpeed.toFixed(1), "| State:", pedalState);
}

window.addEventListener("scroll", () => {
  const currentScrollY = window.scrollY;
  const currentScrollTime = performance.now();

  const deltaY = currentScrollY - lastScrollY;
  const deltaTime = currentScrollTime - lastScrollTime;

  const maxScrollY = document.documentElement.scrollHeight - window.innerHeight;
  const nearTop = currentScrollY <= 0;
  const nearBottom = currentScrollY >= maxScrollY;

  if (deltaTime > 0 && !nearTop && !nearBottom) {
    const scrollSpeed = Math.abs(deltaY / deltaTime);
    const factor = scrollSpeed / MAX_SCROLL_SPEED;
    const clampedSpeed = Math.min(factor * MAX_PEDAL_SPEED, MAX_PEDAL_SPEED);
    updatePedalSpeed(clampedSpeed);
  }

  if (scrollTimeout) clearTimeout(scrollTimeout);
  scrollTimeout = setTimeout(() => {
    // Ease pedal speed down to 0
    const easeOut = () => {
      if (pedalSpeed > 0) {
        updatePedalSpeed(Math.max(0, pedalSpeed - 0.1));
        requestAnimationFrame(easeOut);
      }
    };
    easeOut();
  }, 150);

  lastScrollY = currentScrollY;
  lastScrollTime = currentScrollTime;
});

</script>
